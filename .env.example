# ─────────────────────────────────────────────────────────────────────────────
# Telawat Landing — Environment Variables
#
# How to use:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in the real values below.
#   3. The .env file is git-ignored — never commit real URLs here.
#      For GitHub Actions, add these as Repository Secrets instead.
#      (Settings → Secrets and variables → Actions → New repository secret)
# ─────────────────────────────────────────────────────────────────────────────

# Base URL for GitHub Pages deployment.
# For a project page (https://USER.github.io/REPO), use: /REPO/
# For a user/org page (https://USER.github.io), use:     /
VITE_BASE_URL=/telawat-landing/

# ── Store & Download URLs ─────────────────────────────────────────────────────
# Google Play Store listing URL
VITE_GOOGLE_PLAY_URL=https://play.google.com/store/apps/details?id=YOUR_APP_PACKAGE

# Huawei AppGallery listing URL
VITE_HUAWEI_URL=https://appgallery.huawei.com/app/YOUR_APP_ID

# Direct APK download URL (e.g. a GitHub Release asset)
VITE_APK_URL=https://github.com/YOUR_USERNAME/YOUR_REPO/releases/latest/download/telawat.apk

# ── Donation URL (OPTIONAL) ───────────────────────────────────────────────────
# Link to your donation page (Ko-fi, Buy Me a Coffee, Patreon, etc.).
# The "Donate" button in the Support section only appears when this is set to a
# real URL — leave it empty (or as the YOUR_ placeholder) to hide the button.
VITE_DONATION_URL=https://ko-fi.com/YOUR_PROFILE
